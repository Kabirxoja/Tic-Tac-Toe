<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_background_main_1"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="16dp"
    tools:context=".ui.fragments.InfiniteFragment">

    <RelativeLayout
        android:id="@+id/left_side"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/bac_curve"
        android:gravity="center"
        android:padding="8dp">

        <TextView
            android:id="@+id/txt_user_name_o"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Robot"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:textAllCaps="true"
            android:layout_centerHorizontal="true"
            android:maxLines="1"
            android:ellipsize="end" />

        <RelativeLayout
            android:id="@+id/img_container_o"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txt_user_name_o"
            android:layout_centerHorizontal="true"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bac_cycle" />

            <ImageButton
                android:id="@+id/img_user_o"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/ic_character_woman_1" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/img_container_o"
            android:layout_alignBottom="@+id/img_container_o">
            <ImageView
                android:id="@+id/type_image"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bac_curve"
                android:backgroundTint="@color/white" />
            <ImageView
                android:id="@+id/indicator_user_1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_main_o" />
        </RelativeLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/animation_view1"
            android:layout_width="70dp"
            android:layout_height="35dp"
            android:layout_below="@id/img_container_o"
            android:rotation="180"
            android:visibility="invisible"
            app:lottie_autoPlay="true"
            app:lottie_fileName="json_anim_pointer.json"
            app:lottie_loop="true"
            app:lottie_speed="1.0"
            android:layout_centerHorizontal="true" />
    </RelativeLayout>

    <TextView
        android:id="@+id/score_table_player1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bac_curve"
            android:backgroundTint="#BFE1FF"
            android:padding="6dp"
            android:layout_marginTop="4dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="3">

                <ImageButton android:id="@+id/button00" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button01" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button02" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button10" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button11" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button12" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button20" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button21" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
                <ImageButton android:id="@+id/button22" android:layout_width="75dp" android:layout_height="75dp" android:layout_margin="2dp" android:background="@drawable/bac_curve" android:backgroundTint="@color/white" android:padding="6dp" android:scaleType="centerInside" />
            </GridLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:id="@+id/resetButton"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bac_curve"
            android:backgroundTint="@color/white"
            android:gravity="center">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Reset Game"
                android:src="@drawable/reload" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/replay_game"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/score_table_player2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold" />

    <RelativeLayout
        android:id="@+id/right_side"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/bac_curve"
        android:gravity="center"
        android:padding="8dp">

        <TextView
            android:id="@+id/txt_user_name_x"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Player 2"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:textAllCaps="true"
            android:layout_centerHorizontal="true"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/img_container_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txt_user_name_x"
            android:layout_centerHorizontal="true"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp">
            <ImageButton
                android:id="@+id/img_user_x"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/ic_character_man_3" />
        </LinearLayout>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/img_container_x"
            android:layout_alignBottom="@+id/img_container_x">
            <ImageView
                android:id="@+id/type_image_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bac_curve"
                android:backgroundTint="@color/white" />
            <ImageView
                android:id="@+id/indicator_user_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="6dp"
                android:src="@drawable/ic_main_x" />
        </RelativeLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/animation_view2"
            android:layout_width="70dp"
            android:layout_height="35dp"
            android:layout_below="@id/img_container_x"
            android:rotation="180"
            android:visibility="invisible"
            app:lottie_autoPlay="true"
            app:lottie_fileName="json_anim_pointer.json"
            app:lottie_loop="true"
            app:lottie_speed="1.0"
            android:layout_centerHorizontal="true" />
    </RelativeLayout>

</LinearLayout>